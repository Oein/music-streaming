# --- musicPlayer server ---------------------------------------------------- #
# Base URL of the running Fastify server (no trailing slash).
SERVER_URL=http://192.168.0.10:4300

# Auth: either a long-lived TOKEN, or USERNAME + PASSWORD (preferred, so the
# device can re-login automatically when the 30-day token expires).
MP_USERNAME=admin
MP_PASSWORD=changeme
# TOKEN=

# Set to 1 only if the server uses HTTPS with a self-signed certificate.
# INSECURE_TLS=0

# --- device identity ------------------------------------------------------- #
# Name shown in the app's device picker.
DEVICE_NAME=RPi Player
# Stable id; defaults to one derived from /etc/machine-id if unset.
# DEVICE_ID=

# --- audio ----------------------------------------------------------------- #
# ALSA output for mpv. Find yours with:  mpv --audio-device=help
# For a USB DAC this is typically alsa/hw:1,0 (card 1). Leave unset for default.
ALSA_DEVICE=alsa/hw:1,0

# Path to the mpv binary if not on PATH.
# MPV_PATH=mpv

# LOG_LEVEL=INFO
