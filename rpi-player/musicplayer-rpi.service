[Unit]
Description=musicPlayer RPi playback device
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
# Adjust User/paths to match your install. The user must be in the "audio" group.
User=pi
WorkingDirectory=/home/pi/rpi-player
EnvironmentFile=/home/pi/rpi-player/.env
ExecStart=/home/pi/rpi-player/venv/bin/python /home/pi/rpi-player/player.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
