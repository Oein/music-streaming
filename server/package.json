{
  "name": "musicplayer-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted personal music streaming server",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "seed:admin": "tsx src/scripts/setPassword.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.3",
    "@fastify/websocket": "^11.0.1",
    "@prisma/client": "^6.2.1",
    "@types/sharp": "^0.31.1",
    "argon2": "^0.41.1",
    "chokidar": "^4.0.3",
    "fastify": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.2",
    "music-metadata": "^11.0.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.18.1",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
